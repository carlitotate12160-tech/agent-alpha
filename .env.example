# Agent-Alpha root environment — COPY to .env (gitignored) and fill with real values.
# NEVER commit .env or real secrets.

# DeepSeek API (reasoning + payload provider)
DEEPSEEK_API_KEY=CHANGE_ME

# PostgreSQL event store (matches infra/.env + infra/init-db.sql)
# agent_alpha_app role is created by infra/init-db.sql with NOSUPERUSER NOBYPASSRLS
AGENT_ALPHA_PG_DSN=postgresql://agent_alpha_app:natanael12160@127.0.0.1:5432/agent_alpha

# Redis session store (password must match infra/.env REDIS_PASSWORD)
REDIS_URL=redis://:CHANGE_ME_strong_unique@127.0.0.1:6379/0
