# Copy to .env (gitignored) and set real values on your self-owned box.
# The SHARED password is the crux: it is BOTH the Odoo admin password AND the
# value written into the exposed wp-config.php.bak bait (that is the "reuse").
ODOO_ADMIN_PASSWORD=change-me-shared-reused-pw
ODOO_MASTER_PASSWORD=change-me-master-db-manager-pw
